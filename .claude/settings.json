{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "defaultMode": "acceptEdits",
    "allow": [
      "Read",
      "Edit",
      "Write",
      "Bash(git:*)",
      "Bash(gh:*)",
      "Bash(pnpm install:*)",
      "Bash(pnpm test:*)",
      "Bash(pnpm -r typecheck:*)",
      "Bash(pnpm --filter api build:*)",
      "Bash(pnpm --filter api migrate:*)",
      "Bash(pnpm --filter @nexa/shared build:*)",
      "Bash(node -e:*)",
      "Bash(cargo:*)",
      "Bash(rustc:*)",
      "Bash(rustdoc:*)",
      "Bash(rustfmt:*)",
      "Bash(rustup:*)",
      "Bash(python:*)",
      "Bash(python3:*)",
      "Bash(pip:*)",
      "Bash(pip3:*)",
      "Bash(pytest:*)",
      "Bash(uv:*)",
      "Bash(pwsh:*)",
      "Bash(powershell:*)",
      "Bash(echo:*)",
      "Bash(pwd)",
      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(wc:*)",
      "Bash(awk:*)",
      "Bash(find:*)",
      "Bash(grep:*)",
      "Bash(rg:*)",
      "Bash(which:*)",
      "Bash(file:*)",
      "Bash(date:*)",
      "Bash(tree:*)",
      "Bash(mkdir:*)",
      "Bash(touch:*)",
      "Bash(cp:*)",
      "PowerShell(git:*)",
      "PowerShell(gh:*)",
      "PowerShell(cargo:*)",
      "PowerShell(rustup:*)",
      "PowerShell(python:*)",
      "PowerShell(pip:*)",
      "PowerShell(pwsh:*)",
      "PowerShell(echo:*)",
      "PowerShell(ls:*)",
      "PowerShell(Write-Output:*)",
      "PowerShell(Set-Location:*)",
      "PowerShell(Get-Content:*)",
      "PowerShell(Get-ChildItem:*)",
      "PowerShell(Get-Item:*)",
      "PowerShell(Get-Process:*)",
      "PowerShell(Get-Command:*)",
      "PowerShell(Get-WinEvent:*)",
      "PowerShell(Measure-Object:*)",
      "PowerShell(Select-Object:*)",
      "PowerShell(Select-String:*)",
      "PowerShell(Test-Path:*)",
      "PowerShell(Compare-Object:*)",
      "PowerShell(Format-Table:*)",
      "PowerShell(Format-List:*)"
    ],
    "ask": [
      "Bash(rm:*)",
      "Bash(sudo:*)",
      "Bash(git reset --hard:*)",
      "Bash(git clean:*)",
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "PowerShell(Remove-Item:*)",
      "PowerShell(git reset --hard:*)",
      "PowerShell(git clean:*)",
      "PowerShell(git push --force:*)",
      "PowerShell(git push -f:*)"
    ]
  }
}
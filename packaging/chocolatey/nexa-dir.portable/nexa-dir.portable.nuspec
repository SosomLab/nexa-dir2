<?xml version="1.0" encoding="utf-8"?>
<!--
  Nexa Dir 포터블 — Chocolatey 패키지(docs/21-distribution.md §7).
  ID = nexa-dir.portable (Chocolatey의 .install/.portable 접미사 관례).
  설치형 래퍼 nexa-dir과 달리 설치기를 거치지 않고 포터블 단일 exe를
  패키지 tools\에 내려받아 shim으로 노출한다.
  버전/체크섬은 release.yml이 주입한다 — 수동 편집 금지.
-->
<package xmlns="http://schemas.microsoft.com/packaging/2015/06/nuspec.xsd">
  <metadata>
    <id>nexa-dir.portable</id>
    <version>0.0.0</version>
    <packageSourceUrl>https://github.com/SosomLab/nexa-dir2/tree/main/packaging/chocolatey</packageSourceUrl>
    <owners>SosomLab</owners>

    <title>Nexa Dir (Portable)</title>
    <authors>SosomLab</authors>
    <projectUrl>https://sosomlab.com/apps/nexa-dir/</projectUrl>
    <iconUrl>https://cdn.jsdelivr.net/gh/SosomLab/nexa-dir2@0.8.0/crates/nexa-app/assets/nexa-dir-1024.png</iconUrl>
